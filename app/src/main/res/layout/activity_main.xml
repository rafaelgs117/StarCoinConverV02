<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Glowing sci-fi neon background image generated from attachment analysis -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/img_bg_home_1780055438520"
        android:scaleType="centerCrop"
        android:contentDescription="Fundo Star Coin Convert"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Pure midnight overlay to ensure high text contrast and visual clarity -->
    <!-- Opability modified to D2 (approx 82%) to let world map continents show cleanly -->
    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D2050E1F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Constraints guidelines for clean Material paddings -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/leftGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/rightGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92" />

    <!-- Scrollable container so it fits dynamically on larger, standard or compact screens without cutoffs -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnIrConverter"
        app:layout_constraintStart_toStartOf="@id/leftGuideline"
        app:layout_constraintEnd_toEndOf="@id/rightGuideline">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Custom Vector Premium Star Logo -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_logo_premium"
                android:contentDescription="Logotipo Star Coin Convert"
                android:layout_marginBottom="20dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/gold"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Subheading -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <!-- Short Description Paragraph -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_description"
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp" />

            <!-- Feature description card with glowing border and semi-transparency -->
            <LinearLayout
                android:id="@+id/featuresCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/card_background"
                android:backgroundTint="#B30B1E36"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/features_title"
                    android:textColor="@color/gold"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/features_description"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

            <!-- API Settings Button placed logo abaixo do container que fala sobre o suporte das moedas -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApiSettings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/api_settings"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="bold"
                app:rippleColor="@color/border_blue" />

        </LinearLayout>
    </ScrollView>

    <!-- Main action button exactly matching the golden rounded styling of the screenshots -->
    <!-- Moved slightly upwards from layout_marginBottom 40dp to 90dp -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIrConverter"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginBottom="88dp"
        android:text="@string/btn_start"
        android:textColor="@color/colorOnPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightGuideline"
        app:layout_constraintStart_toEndOf="@id/leftGuideline" />

    <!-- Credit Footer at the bottom - User's name and email in gray color -->
    <TextView
        android:id="@+id/tvUserCredit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/user_credit"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightGuideline"
        app:layout_constraintStart_toStartOf="@id/leftGuideline" />

</androidx.constraintlayout.widget.ConstraintLayout>
